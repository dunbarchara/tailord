{
  "uid": "tailord-per-tailoring-debug-prod",
  "title": "Per-Tailoring Debug (Prod)",
  "schemaVersion": 39,
  "version": 1,
  "editable": true,
  "timezone": "utc",
  "refresh": "10s",
  "time": {
    "from": "now-1h",
    "to": "now"
  },
  "templating": {
    "list": [
      {
        "name": "tailoring_id",
        "label": "Tailoring ID",
        "type": "textbox",
        "current": {
          "value": ""
        },
        "hide": 0
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "title": "Tailoring Metadata",
      "type": "table",
      "gridPos": {
        "x": 0,
        "y": 0,
        "w": 24,
        "h": 4
      },
      "datasource": {
        "uid": "__POSTGRES_UID__",
        "type": "postgres"
      },
      "targets": [
        {
          "refId": "A",
          "rawSql": "SELECT id, generation_status, generation_stage, generation_telemetry->>'duration_ms' AS generation_duration_ms, models->>'letter' AS model, created_at, generated_at FROM tailorings WHERE id = '$tailoring_id'::uuid",
          "format": "table"
        }
      ],
      "fieldConfig": {
        "defaults": {},
        "overrides": []
      },
      "options": {
        "footer": {
          "show": false
        }
      }
    },
    {
      "id": 2,
      "title": "Log Timeline",
      "type": "logs",
      "gridPos": {
        "x": 0,
        "y": 4,
        "w": 24,
        "h": 12
      },
      "datasource": {
        "uid": "__AZURE_MONITOR_UID__",
        "type": "grafana-azure-monitor-datasource"
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "uid": "__AZURE_MONITOR_UID__",
            "type": "grafana-azure-monitor-datasource"
          },
          "queryType": "Azure Log Analytics",
          "azureLogAnalytics": {
            "query": "ContainerAppConsoleLogs_CL\n| where TimeGenerated > ago(1h)\n| where ContainerAppName_s == \"tailord-backend-prod\"\n| extend p = parse_json(Log_s)\n| where tostring(p.tailoring_id) == \"$tailoring_id\"\n| project TimeGenerated, Log_s\n| order by TimeGenerated asc"
          }
        }
      ],
      "fieldConfig": {
        "defaults": {},
        "overrides": []
      },
      "options": {
        "showTime": true,
        "showLabels": false,
        "wrapLogMessage": true,
        "sortOrder": "Ascending"
      }
    },
    {
      "id": 3,
      "title": "TailoringDebugLog Events",
      "type": "table",
      "gridPos": {
        "x": 0,
        "y": 16,
        "w": 24,
        "h": 8
      },
      "datasource": {
        "uid": "__POSTGRES_UID__",
        "type": "postgres"
      },
      "targets": [
        {
          "refId": "A",
          "rawSql": "SELECT created_at, event_type, payload FROM tailoring_debug_logs WHERE tailoring_id = '$tailoring_id'::uuid ORDER BY created_at ASC",
          "format": "table"
        }
      ],
      "fieldConfig": {
        "defaults": {},
        "overrides": []
      },
      "options": {
        "footer": {
          "show": false
        }
      }
    }
  ]
}
