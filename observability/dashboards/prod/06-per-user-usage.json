{
  "uid": "tailord-per-user-usage-prod",
  "title": "Per-User Usage (Prod)",
  "schemaVersion": 39,
  "version": 1,
  "editable": true,
  "timezone": "utc",
  "refresh": "1m",
  "time": {
    "from": "now-30d",
    "to": "now"
  },
  "templating": {
    "list": [
      {
        "name": "user_id",
        "label": "User",
        "type": "query",
        "datasource": {
          "uid": "__POSTGRES_UID__",
          "type": "postgres"
        },
        "query": "SELECT email AS __text, id::text AS __value FROM users WHERE status = 'approved' AND deleted_at IS NULL ORDER BY email",
        "refresh": 2,
        "sort": 0,
        "hide": 0,
        "includeAll": false,
        "multi": false
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "title": "User Details",
      "type": "table",
      "gridPos": {
        "x": 0,
        "y": 0,
        "w": 24,
        "h": 3
      },
      "datasource": {
        "uid": "__POSTGRES_UID__",
        "type": "postgres"
      },
      "targets": [
        {
          "refId": "A",
          "rawSql": "SELECT u.email, u.status, u.is_admin, u.created_at, p.username_slug, p.profile_public FROM users u LEFT JOIN user_profiles p ON p.user_id = u.id WHERE u.id = '$user_id'::uuid",
          "format": "table"
        }
      ],
      "fieldConfig": {
        "defaults": {},
        "overrides": []
      },
      "options": {
        "footer": {
          "show": false
        }
      }
    },
    {
      "id": 2,
      "title": "Total Tailorings",
      "type": "stat",
      "gridPos": {
        "x": 0,
        "y": 3,
        "w": 4,
        "h": 4
      },
      "datasource": {
        "uid": "__POSTGRES_UID__",
        "type": "postgres"
      },
      "targets": [
        {
          "refId": "A",
          "rawSql": "SELECT COUNT(*) AS value FROM tailorings WHERE user_id = '$user_id'::uuid",
          "format": "table"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short"
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        }
      }
    },
    {
      "id": 3,
      "title": "Tailorings This Month",
      "type": "stat",
      "gridPos": {
        "x": 4,
        "y": 3,
        "w": 4,
        "h": 4
      },
      "datasource": {
        "uid": "__POSTGRES_UID__",
        "type": "postgres"
      },
      "targets": [
        {
          "refId": "A",
          "rawSql": "SELECT COUNT(*) AS value FROM llm_usage_logs WHERE user_id = '$user_id'::uuid AND event_type IN ('tailoring_create', 'tailoring_regen') AND created_at >= date_trunc('month', NOW())",
          "format": "table"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "yellow",
                "value": 8
              },
              {
                "color": "red",
                "value": 10
              }
            ]
          }
        },
        "overrides": []
      },
      "description": "tailoring_create + tailoring_regen this calendar month. Thresholds are illustrative \u2014 update when billing tiers ship.",
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        }
      }
    },
    {
      "id": 4,
      "title": "LLM Events Last Hour (Burst)",
      "type": "stat",
      "gridPos": {
        "x": 8,
        "y": 3,
        "w": 4,
        "h": 4
      },
      "datasource": {
        "uid": "__POSTGRES_UID__",
        "type": "postgres"
      },
      "targets": [
        {
          "refId": "A",
          "rawSql": "SELECT COUNT(*) AS value FROM llm_usage_logs WHERE user_id = '$user_id'::uuid AND event_type IN ('tailoring_create', 'tailoring_regen', 'letter_regen') AND created_at >= NOW() - INTERVAL '1 hour'",
          "format": "table"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "yellow",
                "value": 8
              },
              {
                "color": "red",
                "value": 10
              }
            ]
          }
        },
        "overrides": []
      },
      "description": "Hourly burst meter (create + regen + letter_regen). Rate limit fires at 10.",
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        }
      }
    },
    {
      "id": 5,
      "title": "Active Claims",
      "type": "stat",
      "gridPos": {
        "x": 12,
        "y": 3,
        "w": 4,
        "h": 4
      },
      "datasource": {
        "uid": "__POSTGRES_UID__",
        "type": "postgres"
      },
      "targets": [
        {
          "refId": "A",
          "rawSql": "SELECT COUNT(*) AS value FROM experience_claims WHERE user_id = '$user_id'::uuid AND status = 'active'",
          "format": "table"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short"
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        }
      }
    },
    {
      "id": 6,
      "title": "Shared Tailorings",
      "type": "stat",
      "gridPos": {
        "x": 16,
        "y": 3,
        "w": 4,
        "h": 4
      },
      "datasource": {
        "uid": "__POSTGRES_UID__",
        "type": "postgres"
      },
      "targets": [
        {
          "refId": "A",
          "rawSql": "SELECT COUNT(*) AS value FROM tailorings WHERE user_id = '$user_id'::uuid AND (letter_public OR posting_public)",
          "format": "table"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short"
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        }
      }
    },
    {
      "id": 7,
      "title": "Notion Connected",
      "type": "stat",
      "gridPos": {
        "x": 20,
        "y": 3,
        "w": 4,
        "h": 4
      },
      "datasource": {
        "uid": "__POSTGRES_UID__",
        "type": "postgres"
      },
      "targets": [
        {
          "refId": "A",
          "rawSql": "SELECT CASE WHEN COUNT(*) > 0 THEN 1 ELSE 0 END AS value FROM user_integrations WHERE user_id = '$user_id'::uuid AND provider = 'notion'",
          "format": "table"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "mappings": [
            {
              "type": "value",
              "options": {
                "0": {
                  "text": "No",
                  "color": "text"
                },
                "1": {
                  "text": "Yes",
                  "color": "green"
                }
              }
            }
          ]
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        }
      }
    },
    {
      "id": 8,
      "title": "LLM Events Over Time (30d)",
      "type": "timeseries",
      "gridPos": {
        "x": 0,
        "y": 7,
        "w": 14,
        "h": 9
      },
      "datasource": {
        "uid": "__POSTGRES_UID__",
        "type": "postgres"
      },
      "targets": [
        {
          "refId": "A",
          "rawSql": "SELECT date_trunc('day', created_at) AS time, COUNT(*) AS tailoring_create FROM llm_usage_logs WHERE user_id = '$user_id'::uuid AND event_type = 'tailoring_create' AND created_at >= NOW() - INTERVAL '30 days' GROUP BY 1 ORDER BY 1",
          "format": "time_series"
        },
        {
          "refId": "B",
          "rawSql": "SELECT date_trunc('day', created_at) AS time, COUNT(*) AS tailoring_regen FROM llm_usage_logs WHERE user_id = '$user_id'::uuid AND event_type = 'tailoring_regen' AND created_at >= NOW() - INTERVAL '30 days' GROUP BY 1 ORDER BY 1",
          "format": "time_series"
        },
        {
          "refId": "C",
          "rawSql": "SELECT date_trunc('day', created_at) AS time, COUNT(*) AS letter_regen FROM llm_usage_logs WHERE user_id = '$user_id'::uuid AND event_type = 'letter_regen' AND created_at >= NOW() - INTERVAL '30 days' GROUP BY 1 ORDER BY 1",
          "format": "time_series"
        },
        {
          "refId": "D",
          "rawSql": "SELECT date_trunc('day', created_at) AS time, COUNT(*) AS resume_process FROM llm_usage_logs WHERE user_id = '$user_id'::uuid AND event_type = 'resume_process' AND created_at >= NOW() - INTERVAL '30 days' GROUP BY 1 ORDER BY 1",
          "format": "time_series"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short"
        },
        "overrides": []
      }
    },
    {
      "id": 9,
      "title": "Claims by Source Type",
      "type": "bargauge",
      "gridPos": {
        "x": 14,
        "y": 7,
        "w": 10,
        "h": 9
      },
      "datasource": {
        "uid": "__POSTGRES_UID__",
        "type": "postgres"
      },
      "targets": [
        {
          "refId": "A",
          "rawSql": "SELECT source_type AS metric, COUNT(*) AS value FROM experience_claims WHERE user_id = '$user_id'::uuid AND status = 'active' GROUP BY 1 ORDER BY 2 DESC",
          "format": "table"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short"
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "orientation": "horizontal"
      }
    },
    {
      "id": 10,
      "title": "Experience Sources",
      "type": "table",
      "gridPos": {
        "x": 0,
        "y": 16,
        "w": 12,
        "h": 7
      },
      "datasource": {
        "uid": "__POSTGRES_UID__",
        "type": "postgres"
      },
      "targets": [
        {
          "refId": "A",
          "rawSql": "SELECT source_type, connection_status, sync_status, last_synced_at, last_requested_at, error_message FROM experience_sources WHERE user_id = '$user_id'::uuid ORDER BY source_type",
          "format": "table"
        }
      ],
      "fieldConfig": {
        "defaults": {},
        "overrides": []
      },
      "options": {
        "footer": {
          "show": false
        }
      }
    },
    {
      "id": 11,
      "title": "Recent Tailorings",
      "type": "table",
      "gridPos": {
        "x": 12,
        "y": 16,
        "w": 12,
        "h": 7
      },
      "datasource": {
        "uid": "__POSTGRES_UID__",
        "type": "postgres"
      },
      "targets": [
        {
          "refId": "A",
          "rawSql": "SELECT t.id, j.extracted_job->>'title' AS job_title, j.extracted_job->>'company' AS company, t.generation_status, t.letter_public OR t.posting_public AS shared, t.created_at FROM tailorings t JOIN jobs j ON j.id = t.job_id WHERE t.user_id = '$user_id'::uuid ORDER BY t.created_at DESC LIMIT 20",
          "format": "table"
        }
      ],
      "fieldConfig": {
        "defaults": {},
        "overrides": []
      },
      "options": {
        "footer": {
          "show": false
        }
      }
    },
    {
      "id": 12,
      "title": "Recent LLM Events",
      "type": "table",
      "gridPos": {
        "x": 0,
        "y": 23,
        "w": 24,
        "h": 7
      },
      "datasource": {
        "uid": "__POSTGRES_UID__",
        "type": "postgres"
      },
      "targets": [
        {
          "refId": "A",
          "rawSql": "SELECT created_at, event_type, model, input_tokens, output_tokens, cost_usd FROM llm_usage_logs WHERE user_id = '$user_id'::uuid ORDER BY created_at DESC LIMIT 50",
          "format": "table"
        }
      ],
      "fieldConfig": {
        "defaults": {},
        "overrides": []
      },
      "options": {
        "footer": {
          "show": false
        }
      }
    }
  ]
}
