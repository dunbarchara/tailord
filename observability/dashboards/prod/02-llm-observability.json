{
  "uid": "tailord-llm-observability-prod",
  "title": "LLM Observability (Prod)",
  "schemaVersion": 39,
  "version": 1,
  "editable": true,
  "timezone": "utc",
  "refresh": "30s",
  "time": {
    "from": "now-1h",
    "to": "now"
  },
  "templating": {
    "list": []
  },
  "panels": [
    {
      "id": 1,
      "title": "LLM Call Rate",
      "type": "timeseries",
      "gridPos": {
        "x": 0,
        "y": 0,
        "w": 12,
        "h": 8
      },
      "datasource": {
        "uid": "__PROMETHEUS_UID__",
        "type": "prometheus"
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(rate(llm_call_duration_ms_count{environment=\"production\"}[5m])) by (model, prompt_type)",
          "legendFormat": "{{model}} / {{prompt_type}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "reqps"
        },
        "overrides": []
      }
    },
    {
      "id": 2,
      "title": "Model Distribution (24h)",
      "type": "piechart",
      "gridPos": {
        "x": 12,
        "y": 0,
        "w": 12,
        "h": 8
      },
      "datasource": {
        "uid": "__PROMETHEUS_UID__",
        "type": "prometheus"
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(increase(llm_call_duration_ms_count{environment=\"production\"}[24h])) by (model)",
          "legendFormat": "{{model}}"
        }
      ],
      "fieldConfig": {
        "defaults": {},
        "overrides": []
      }
    },
    {
      "id": 3,
      "title": "P50 Latency by Prompt Type",
      "type": "timeseries",
      "gridPos": {
        "x": 0,
        "y": 8,
        "w": 12,
        "h": 8
      },
      "datasource": {
        "uid": "__PROMETHEUS_UID__",
        "type": "prometheus"
      },
      "targets": [
        {
          "refId": "A",
          "expr": "histogram_quantile(0.50, sum(rate(llm_call_duration_ms_bucket{environment=\"production\"}[5m])) by (le, prompt_type))",
          "legendFormat": "p50 {{prompt_type}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ms"
        },
        "overrides": []
      }
    },
    {
      "id": 4,
      "title": "P95 Latency by Prompt Type",
      "type": "timeseries",
      "gridPos": {
        "x": 12,
        "y": 8,
        "w": 12,
        "h": 8
      },
      "datasource": {
        "uid": "__PROMETHEUS_UID__",
        "type": "prometheus"
      },
      "targets": [
        {
          "refId": "A",
          "expr": "histogram_quantile(0.95, sum(rate(llm_call_duration_ms_bucket{environment=\"production\"}[5m])) by (le, prompt_type))",
          "legendFormat": "p95 {{prompt_type}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ms"
        },
        "overrides": []
      }
    },
    {
      "id": 5,
      "title": "Input Tokens/s",
      "type": "timeseries",
      "gridPos": {
        "x": 0,
        "y": 16,
        "w": 8,
        "h": 7
      },
      "datasource": {
        "uid": "__PROMETHEUS_UID__",
        "type": "prometheus"
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(rate(llm_tokens_total{direction=\"input\",environment=\"production\"}[5m])) by (prompt_type)",
          "legendFormat": "{{prompt_type}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short"
        },
        "overrides": []
      }
    },
    {
      "id": 6,
      "title": "Output Tokens/s",
      "type": "timeseries",
      "gridPos": {
        "x": 8,
        "y": 16,
        "w": 8,
        "h": 7
      },
      "datasource": {
        "uid": "__PROMETHEUS_UID__",
        "type": "prometheus"
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(rate(llm_tokens_total{direction=\"output\",environment=\"production\"}[5m])) by (prompt_type)",
          "legendFormat": "{{prompt_type}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short"
        },
        "overrides": []
      }
    },
    {
      "id": 7,
      "title": "LLM Error Rate",
      "type": "timeseries",
      "gridPos": {
        "x": 16,
        "y": 16,
        "w": 8,
        "h": 7
      },
      "datasource": {
        "uid": "__PROMETHEUS_UID__",
        "type": "prometheus"
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(rate(llm_errors_total{environment=\"production\"}[5m])) by (error_type)",
          "legendFormat": "{{error_type}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "color": {
            "mode": "fixed",
            "fixedColor": "red"
          }
        },
        "overrides": []
      }
    },
    {
      "id": 8,
      "title": "LLM Retry Rate",
      "type": "timeseries",
      "gridPos": {
        "x": 0,
        "y": 23,
        "w": 12,
        "h": 7
      },
      "datasource": {
        "uid": "__PROMETHEUS_UID__",
        "type": "prometheus"
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(rate(llm_retries_total{environment=\"production\"}[5m])) by (prompt_type)",
          "legendFormat": "{{prompt_type}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "reqps"
        },
        "overrides": []
      }
    },
    {
      "id": 9,
      "title": "Cached Input Tokens/s",
      "type": "timeseries",
      "gridPos": {
        "x": 0,
        "y": 30,
        "w": 12,
        "h": 7
      },
      "datasource": {
        "uid": "__PROMETHEUS_UID__",
        "type": "prometheus"
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(rate(llm_cached_tokens_total{environment=\"production\"}[5m])) by (prompt_type)",
          "legendFormat": "{{prompt_type}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short"
        },
        "overrides": []
      },
      "description": "Rate of cached input tokens by prompt type. Confirms cache hit patterns for chunk scoring calls."
    },
    {
      "id": 10,
      "title": "Embedding Tokens/s by Context",
      "type": "timeseries",
      "gridPos": {
        "x": 12,
        "y": 30,
        "w": 12,
        "h": 7
      },
      "datasource": {
        "uid": "__PROMETHEUS_UID__",
        "type": "prometheus"
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(rate(embedding_tokens_total{environment=\"production\"}[5m])) by (embed_context)",
          "legendFormat": "{{embed_context}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short"
        },
        "overrides": []
      }
    },
    {
      "id": 11,
      "title": "LLM Calls by Prompt \u00d7 Model",
      "type": "table",
      "gridPos": {
        "x": 0,
        "y": 37,
        "w": 24,
        "h": 9
      },
      "datasource": {
        "uid": "__POSTGRES_UID__",
        "type": "postgres"
      },
      "targets": [
        {
          "refId": "A",
          "rawSql": "SELECT\n  prompt_name,\n  model,\n  call_type,\n  COUNT(*)                    AS calls,\n  SUM(input_tokens)           AS input_tokens,\n  SUM(cached_tokens)          AS cached_tokens,\n  SUM(output_tokens)          AS output_tokens,\n  ROUND(AVG(latency_ms))::int AS avg_latency_ms,\n  ROUND(SUM(\n    CASE model\n      WHEN 'gpt-5.4-mini' THEN\n        (COALESCE(input_tokens,0) - COALESCE(cached_tokens,0)) * 0.75  / 1000000.0\n        + COALESCE(cached_tokens,0)                                     * 0.08  / 1000000.0\n        + COALESCE(output_tokens,0)                                     * 4.50  / 1000000.0\n      WHEN 'gpt-5.4' THEN\n        (COALESCE(input_tokens,0) - COALESCE(cached_tokens,0)) * 2.50  / 1000000.0\n        + COALESCE(cached_tokens,0)                                     * 0.25  / 1000000.0\n        + COALESCE(output_tokens,0)                                     * 15.00 / 1000000.0\n      WHEN 'text-embedding-3-small' THEN\n        COALESCE(input_tokens,0)                                        * 0.025 / 1000000.0\n      ELSE 0\n    END\n  ), 8) AS cost_usd\nFROM llm_call_logs\nWHERE created_at BETWEEN $__timeFrom() AND $__timeTo()\nGROUP BY prompt_name, model, call_type\nORDER BY cost_usd DESC NULLS LAST",
          "format": "table"
        }
      ],
      "fieldConfig": {
        "defaults": {},
        "overrides": []
      },
      "description": "Sorted by estimated cost. Pricing: backend/app/core/llm_pricing.py",
      "options": {
        "footer": {
          "show": false
        }
      }
    },
    {
      "id": 12,
      "title": "LLM Calls by User",
      "type": "table",
      "gridPos": {
        "x": 0,
        "y": 46,
        "w": 24,
        "h": 9
      },
      "datasource": {
        "uid": "__POSTGRES_UID__",
        "type": "postgres"
      },
      "targets": [
        {
          "refId": "A",
          "rawSql": "SELECT\n  COALESCE(u.email, '(system)') AS user,\n  l.model,\n  COUNT(*)                       AS calls,\n  SUM(l.input_tokens)            AS input_tokens,\n  SUM(l.cached_tokens)           AS cached_tokens,\n  SUM(l.output_tokens)           AS output_tokens,\n  ROUND(SUM(\n    CASE l.model\n      WHEN 'gpt-5.4-mini' THEN\n        (COALESCE(l.input_tokens,0) - COALESCE(l.cached_tokens,0)) * 0.75  / 1000000.0\n        + COALESCE(l.cached_tokens,0)                              * 0.08  / 1000000.0\n        + COALESCE(l.output_tokens,0)                              * 4.50  / 1000000.0\n      WHEN 'gpt-5.4' THEN\n        (COALESCE(l.input_tokens,0) - COALESCE(l.cached_tokens,0)) * 2.50  / 1000000.0\n        + COALESCE(l.cached_tokens,0)                              * 0.25  / 1000000.0\n        + COALESCE(l.output_tokens,0)                              * 15.00 / 1000000.0\n      WHEN 'text-embedding-3-small' THEN\n        COALESCE(l.input_tokens,0)                                 * 0.025 / 1000000.0\n      ELSE 0\n    END\n  ), 8) AS cost_usd\nFROM llm_call_logs l\nLEFT JOIN users u ON u.id = l.user_id\nWHERE l.created_at BETWEEN $__timeFrom() AND $__timeTo()\nGROUP BY u.email, l.model\nORDER BY cost_usd DESC NULLS LAST",
          "format": "table"
        }
      ],
      "fieldConfig": {
        "defaults": {},
        "overrides": []
      },
      "options": {
        "footer": {
          "show": false
        }
      }
    }
  ]
}
