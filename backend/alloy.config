// Grafana Alloy — unified local observability collector.
// Replaces Promtail (EOL). Handles logs, metrics, and traces.
//
// Log shipping uses inotify via VirtioFS (Docker Desktop file sharing).
// Metrics are scraped and remote-written to Prometheus.
// OTLP traces are received and forwarded to Tempo.

// ============================================================
// METRICS — scrape FastAPI backend → remote_write to Prometheus
// ============================================================

prometheus.scrape "tailord_backend" {
  targets = [{
    __address__ = "host.docker.internal:8000",
    job         = "tailord-backend",
  }]
  metrics_path    = "/metrics"
  scrape_interval = "15s"
  forward_to      = [prometheus.remote_write.local_prometheus.receiver]
}

prometheus.remote_write "local_prometheus" {
  endpoint {
    url = "http://prometheus:9090/api/v1/write"
  }
}

// ============================================================
// TRACES — receive OTLP → forward to Tempo
// ============================================================

otelcol.receiver.otlp "default" {
  grpc {
    endpoint = "0.0.0.0:4317"
  }
  http {
    endpoint = "0.0.0.0:4318"
  }

  output {
    traces = [otelcol.exporter.otlphttp.tempo.input]
  }
}

otelcol.exporter.otlphttp "tempo" {
  client {
    endpoint = "http://tempo:4318"
  }
}
