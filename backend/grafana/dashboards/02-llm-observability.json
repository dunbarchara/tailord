{
  "uid": "tailord-llm-observability-prod",
  "title": "LLM Observability (Prod)",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "30s",
  "time": { "from": "now-1h", "to": "now" },
  "templating": { "list": [] },
  "panels": [
    {
      "id": 1,
      "title": "LLM Call Rate",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 0, "w": 12, "h": 8 },
      "datasource": { "uid": "__PROMETHEUS_UID__", "type": "prometheus" },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(rate(llm_call_duration_ms_count{environment=\"production\"}[5m])) by (model, prompt_type)",
          "legendFormat": "{{model}} / {{prompt_type}}"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "reqps" },
        "overrides": []
      }
    },
    {
      "id": 2,
      "title": "Model Distribution (24h)",
      "type": "piechart",
      "gridPos": { "x": 12, "y": 0, "w": 12, "h": 8 },
      "datasource": { "uid": "__PROMETHEUS_UID__", "type": "prometheus" },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(increase(llm_call_duration_ms_count{environment=\"production\"}[24h])) by (model)",
          "legendFormat": "{{model}}"
        }
      ],
      "fieldConfig": { "defaults": {}, "overrides": [] }
    },
    {
      "id": 3,
      "title": "P50 Latency by Prompt Type",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 8, "w": 12, "h": 8 },
      "datasource": { "uid": "__PROMETHEUS_UID__", "type": "prometheus" },
      "targets": [
        {
          "refId": "A",
          "expr": "histogram_quantile(0.50, sum(rate(llm_call_duration_ms_bucket{environment=\"production\"}[5m])) by (le, prompt_type))",
          "legendFormat": "p50 {{prompt_type}}"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "ms" },
        "overrides": []
      }
    },
    {
      "id": 4,
      "title": "P95 Latency by Prompt Type",
      "type": "timeseries",
      "gridPos": { "x": 12, "y": 8, "w": 12, "h": 8 },
      "datasource": { "uid": "__PROMETHEUS_UID__", "type": "prometheus" },
      "targets": [
        {
          "refId": "A",
          "expr": "histogram_quantile(0.95, sum(rate(llm_call_duration_ms_bucket{environment=\"production\"}[5m])) by (le, prompt_type))",
          "legendFormat": "p95 {{prompt_type}}"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "ms" },
        "overrides": []
      }
    },
    {
      "id": 5,
      "title": "Input Tokens/s",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 16, "w": 8, "h": 7 },
      "datasource": { "uid": "__PROMETHEUS_UID__", "type": "prometheus" },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(rate(llm_tokens_total{direction=\"input\",environment=\"production\"}[5m])) by (prompt_type)",
          "legendFormat": "{{prompt_type}}"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "short" },
        "overrides": []
      }
    },
    {
      "id": 6,
      "title": "Output Tokens/s",
      "type": "timeseries",
      "gridPos": { "x": 8, "y": 16, "w": 8, "h": 7 },
      "datasource": { "uid": "__PROMETHEUS_UID__", "type": "prometheus" },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(rate(llm_tokens_total{direction=\"output\",environment=\"production\"}[5m])) by (prompt_type)",
          "legendFormat": "{{prompt_type}}"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "short" },
        "overrides": []
      }
    },
    {
      "id": 7,
      "title": "LLM Error Rate",
      "type": "timeseries",
      "gridPos": { "x": 16, "y": 16, "w": 8, "h": 7 },
      "datasource": { "uid": "__PROMETHEUS_UID__", "type": "prometheus" },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(rate(llm_errors_total{environment=\"production\"}[5m])) by (error_type)",
          "legendFormat": "{{error_type}}"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "reqps", "color": { "mode": "fixed", "fixedColor": "red" } },
        "overrides": []
      }
    },
    {
      "id": 8,
      "title": "LLM Retry Rate",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 23, "w": 12, "h": 7 },
      "datasource": { "uid": "__PROMETHEUS_UID__", "type": "prometheus" },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(rate(llm_retries_total{environment=\"production\"}[5m])) by (prompt_type)",
          "legendFormat": "{{prompt_type}}"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "reqps" },
        "overrides": []
      }
    }
  ]
}
