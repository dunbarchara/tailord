{
  "uid": "tailord-user-activity",
  "title": "User Activity",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "5m",
  "time": { "from": "now-30d", "to": "now" },
  "templating": { "list": [] },
  "panels": [
    {
      "id": 1,
      "title": "Total Users",
      "type": "stat",
      "gridPos": { "x": 0, "y": 0, "w": 4, "h": 4 },
      "datasource": { "uid": "postgres-local", "type": "postgres" },
      "targets": [
        {
          "refId": "A",
          "rawSql": "SELECT COUNT(*) AS value FROM users",
          "format": "table"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "short" },
        "overrides": []
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] } }
    },
    {
      "id": 2,
      "title": "Approved Users",
      "type": "stat",
      "gridPos": { "x": 4, "y": 0, "w": 4, "h": 4 },
      "datasource": { "uid": "postgres-local", "type": "postgres" },
      "targets": [
        {
          "refId": "A",
          "rawSql": "SELECT COUNT(*) AS value FROM users WHERE status = 'approved'",
          "format": "table"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "short" },
        "overrides": []
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] } }
    },
    {
      "id": 3,
      "title": "Experience Success Rate (7d)",
      "type": "stat",
      "gridPos": { "x": 8, "y": 0, "w": 4, "h": 4 },
      "datasource": { "uid": "postgres-local", "type": "postgres" },
      "targets": [
        {
          "refId": "A",
          "rawSql": "SELECT ROUND(100.0 * COUNT(*) FILTER (WHERE status = 'ready') / NULLIF(COUNT(*), 0), 1) AS value FROM experiences WHERE processed_at >= NOW() - INTERVAL '7 days'",
          "format": "table"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "yellow", "value": 80 },
              { "color": "green", "value": 95 }
            ]
          }
        },
        "overrides": []
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] } }
    },
    {
      "id": 4,
      "title": "Generation Status Distribution",
      "type": "bargauge",
      "gridPos": { "x": 12, "y": 0, "w": 12, "h": 4 },
      "datasource": { "uid": "postgres-local", "type": "postgres" },
      "targets": [
        {
          "refId": "A",
          "rawSql": "SELECT generation_status AS metric, COUNT(*) AS value FROM tailorings GROUP BY generation_status",
          "format": "table"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "short" },
        "overrides": []
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "orientation": "horizontal" }
    },
    {
      "id": 5,
      "title": "Tailorings per Day (30d)",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 4, "w": 12, "h": 9 },
      "datasource": { "uid": "postgres-local", "type": "postgres" },
      "targets": [
        {
          "refId": "A",
          "rawSql": "SELECT date_trunc('day', created_at) AS time, COUNT(*) AS tailorings FROM tailorings WHERE created_at >= NOW() - INTERVAL '30 days' GROUP BY 1 ORDER BY 1",
          "format": "time_series"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "short" },
        "overrides": []
      }
    },
    {
      "id": 6,
      "title": "Active Users per Day (30d)",
      "type": "timeseries",
      "gridPos": { "x": 12, "y": 4, "w": 12, "h": 9 },
      "datasource": { "uid": "postgres-local", "type": "postgres" },
      "targets": [
        {
          "refId": "A",
          "rawSql": "SELECT date_trunc('day', created_at) AS time, COUNT(DISTINCT user_id) AS users FROM tailorings WHERE created_at >= NOW() - INTERVAL '30 days' GROUP BY 1 ORDER BY 1",
          "format": "time_series"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "short" },
        "overrides": []
      }
    }
  ]
}
