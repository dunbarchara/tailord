// Grafana Alloy config for native macOS log tailing.
//
// inotify does not fire inside Docker containers on macOS bind mounts,
// so log tailing must run natively where FSEvents/kqueue work correctly.
// Metrics and traces are handled by the Docker-based Alloy (alloy.config).
//
// Setup (one-time):
//   brew install grafana/grafana/alloy
//
// Run (from backend/):
//   alloy run alloy-native.config

local.file_match "tailord" {
  path_targets = [{
    __path__ = "./logs/app.jsonl",
    job      = "tailord-backend",
  }]
}

loki.source.file "tailord" {
  targets    = local.file_match.tailord.targets
  forward_to = [loki.process.tailord.receiver]
}

loki.process "tailord" {
  forward_to = [loki.write.default.receiver]

  stage.json {
    expressions = {
      level     = "level",
      logger    = "logger",
      timestamp = "timestamp",
    }
  }

  stage.labels {
    values = {
      level  = null,
      logger = null,
    }
  }

  stage.timestamp {
    source = "timestamp"
    format = "RFC3339Nano"
  }
}

loki.write "default" {
  endpoint {
    url = "http://localhost:3100/loki/api/v1/push"
  }
}
