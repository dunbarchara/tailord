############################################
# Root
############################################

.env
.env.*
!.env.example

.DS_Store
Thumbs.db

############################################
# Node / Next.js (frontend)
############################################

# dependencies
frontend/node_modules/

# Next.js build output
frontend/.next/
frontend/out/

# Logs
frontend/npm-debug.log*
frontend/yarn-debug.log*
frontend/yarn-error.log*
frontend/pnpm-debug.log*

# Vercel
frontend/.vercel/

# TypeScript
frontend/*.tsbuildinfo
frontend/next-env.d.ts

############################################
# Python / uv (backend)
############################################

# Local dev scripts (never ship to prod)
backend/dev_*.py

# Python bytecode
backend/__pycache__/
backend/**/*.py[cod]

# uv virtual environments (if created)
backend/.venv/

# Build artifacts
backend/build/
backend/dist/
backend/*.egg-info/

# local logs
backend/logs/

# pytest
backend/.pytest_cache/

# Coverage
backend/.coverage
backend/htmlcov/

############################################
# Playwright
############################################

# Playwright downloads (optional – see note below)
backend/playwright-report/
backend/playwright/.cache/

############################################
# Docker
############################################

*.log
docker-compose.override.yml

############################################
# IDEs / Editors
############################################

.vscode/
.idea/
*.swp
*.swo

############################################
# OS-level
############################################

.DS_Store
Thumbs.db

############################################
# Terraform
############################################

*.terraform*
*.tfstate*
!*.terraform.lock.hcl